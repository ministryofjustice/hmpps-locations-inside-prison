{
  "compilerOptions": {
    "target": "es2015",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["es2015", "dom"],
    "noEmit": true,
    "types": ["cypress", "express", "express-session"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "noImplicitAny": false
  },
  "include": ["**/*.ts", "../cypress.config.ts"]
}
