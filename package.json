{
  "name": "hmpps-locations-inside-prison",
  "version": "0.0.1",
  "description": "Residential locations",
  "repository": "git@github.com:ministryofjustice/hmpps-locations-inside-prison.git",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "watch-ts": "tsc -w",
    "build": "node esbuild/esbuild.config.js --build",
    "start": "node $NODE_OPTIONS dist/server.js | bunyan -o short",
    "start:dev": "concurrently -k -p \"[{name}]\" -n \"ESBuild,Node\" -c \"yellow.bold,cyan.bold\" \"node esbuild/esbuild.config.js --build --watch\" \"node esbuild/esbuild.config.js --dev-server\"",
    "start-feature": " node $NODE_DEBUG_OPTION --env-file=feature.env dist/server.js | bunyan -o short",
    "start-feature:dev": "concurrently -k -p \"[{name}]\" -n \"ESBuild,Node\" -c \"yellow.bold,cyan.bold\" \"node esbuild/esbuild.config.js  --build --watch \" \"node esbuild/esbuild.config.js --dev-test-server\"",
    "lint": "eslint . --cache --max-warnings 0",
    "lint-fix": "eslint . --cache --max-warnings 0 --fix",
    "typecheck": "tsc && tsc -p integration_tests",
    "test": "jest",
    "test-coverage": "jest --coverage",
    "test:ci": "jest --runInBand --coverage --coverageDirectory=coverage",
    "security_audit": "npx audit-ci --config audit-ci.json",
    "int-test": "cypress run --config video=false",
    "int-test-ui": "cypress open --e2e --browser chrome",
    "clean": "rm -rf dist node_modules",
    "precommit:lint": "lint-staged",
    "precommit:secrets": "gitleaks git --pre-commit --redact --staged --verbose --config .gitleaks/config.toml --gitleaks-ignore-path .gitleaks/.gitleaksignore",
    "precommit:verify": "npm run typecheck && npm test",
    "rebuild": "npm run clean && npm i && npm run build",
    "setup": "npm ci && hmpps-npm-script-run-allowlist"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "jest": {
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest"
      ]
    },
    "collectCoverageFrom": [
      "server/**/*.{ts,js,jsx,mjs}"
    ],
    "testMatch": [
      "<rootDir>/(server|job)/**/?(*.)(cy|test).{ts,js,jsx,mjs}"
    ],
    "testEnvironment": "node",
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test_results/jest/"
        }
      ],
      [
        "./node_modules/jest-html-reporter",
        {
          "outputPath": "test_results/unit-test-reports.html"
        }
      ]
    ],
    "moduleFileExtensions": [
      "web.js",
      "js",
      "json",
      "node",
      "ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 0,
        "functions": 0,
        "lines": 0,
        "statements": 0
      }
    }
  },
  "lint-staged": {
    "*.{ts,js,css}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "3.1052.0",
    "@ministryofjustice/frontend": "^8.0.1",
    "@ministryofjustice/hmpps-auth-clients": "^2.0.0",
    "@ministryofjustice/hmpps-monitoring": "^2.1.0",
    "@ministryofjustice/hmpps-rest-client": "^2.1.0",
    "applicationinsights": "^2.9.8",
    "axe-core": "^4.11.4",
    "body-parser": "^2.2.2",
    "bunyan": "^1.8.15",
    "bunyan-format": "^0.2.1",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-redis": "^8.1.0",
    "cookie-parser": "^1.4.7",
    "csrf-sync": "^4.2.1",
    "date-fns": "^4.2.1",
    "express": "^4.22.2",
    "express-async-errors": "^3.1.1",
    "express-session": "^1.19.0",
    "govuk-frontend": "^5.14.0",
    "helmet": "^8.2.0",
    "hmpo-form-wizard": "^17.0.1",
    "http-errors": "^2.0.1",
    "jquery": "^4.0.0",
    "jwt-decode": "^4.0.0",
    "lodash": "4.18.1",
    "minimatch": "^10.2.5",
    "multer": "^2.1.1",
    "nocache": "^4.0.0",
    "notifications-node-client": "8.4.0",
    "nunjucks": "^3.2.4",
    "passport": "^0.7.0",
    "passport-oauth2": "^1.8.0",
    "prom-client": "^15.1.3",
    "redis": "^4.7.1",
    "source-map-support": "^0.5.21",
    "superagent": "^10.3.0",
    "url-value-parser": "^2.2.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@cypress/webpack-batteries-included-preprocessor": "^3.1.2",
    "@cypress/webpack-preprocessor": "^5.17.1",
    "@jest/globals": "^30.4.1",
    "@jgoz/esbuild-plugin-typecheck": "^4.0.4",
    "@ministryofjustice/eslint-config-hmpps": "^1.0.3",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.6",
    "@ministryofjustice/hmpps-precommit-hooks": "^3.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/bunyan": "^1.8.11",
    "@types/bunyan-format": "^0.2.9",
    "@types/compression": "^1.8.1",
    "@types/connect-flash": "0.0.40",
    "@types/cookie-parser": "^1.4.10",
    "@types/cookie-session": "^2.0.49",
    "@types/express-session": "^1.19.0",
    "@types/http-errors": "^2.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.4",
    "@types/nunjucks": "^3.2.6",
    "@types/nunjucks-date": "^0.0.10",
    "@types/parseurl": "^1.3.3",
    "@types/passport": "^1.0.17",
    "@types/passport-oauth2": "^1.8.0",
    "@types/superagent": "^8.1.10",
    "@types/supertest": "^7.2.0",
    "audit-ci": "^7.1.0",
    "aws-sdk-client-mock": "^4.1.0",
    "chokidar": "^3.6.0",
    "concurrently": "^9.2.1",
    "cookie-session": "^2.1.1",
    "cypress": "15.15.0",
    "cypress-axe": "^1.7.0",
    "cypress-multi-reporters": "^2.0.5",
    "cypress-split": "^1.24.31",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "esbuild-plugin-clean": "^1.0.1",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-manifest": "^1.0.5",
    "esbuild-sass-plugin": "^3.7.0",
    "fishery": "^2.4.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "jest": "30.4.2",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^17.0.0",
    "jest-mock": "^30.4.1",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "17.0.5",
    "mocha-junit-reporter": "^2.2.1",
    "nock": "^14.0.15",
    "prettier": "^3.8.3",
    "prettier-plugin-jinja-template": "^2.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "axios": ">=1.16.1",
    "@types/express": "5.0.6",
    "@types/express-serve-static-core": "5.1.1",
    "@jgoz/esbuild-plugin-typecheck": {
      "esbuild": "$esbuild"
    },
    "cypress-multi-reporters": {
      "mocha": {
        "serialize-javascript": "7.0.5"
      }
    },
    "jest": {
      "jest-core": {
        "micromatch": "4.0.8"
      }
    },
    "diff": "9.0.0"
  }
}
