{% extends "../../partials/layout.njk" %}

{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <p class="govuk-body">
          There is already an existing cell certificate change request for a location in {{decoratedLocation.displayName | capFirst}}.
        </p>

        <p class="govuk-body">
          You can wait for this request to be approved or you can withdraw the request if you need to.
        </p>

        <p class="govuk-body">
          <a href="{{ changeRequestsLink }}" class="govuk-link govuk-link--no-visited-state">
            View change requests
          </a>
        </p>

        <p class="govuk-body">
          <a href="{{ cancelLink }}" class="govuk-link govuk-link--no-visited-state">
            Return to location details
          </a>
        </p>
      </div>
    </div>
  </div>
{% endblock %}
